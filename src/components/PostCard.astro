---
import type { CollectionEntry } from "astro:content";

type Props = {
    post: CollectionEntry<"blog">;
};

const { post } = Astro.props as Props;
const { title, description, date, tags } = post.data;

const dateString = date.toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
});
---

<a
    href={`/blog/${post.id}`}
    class="flex flex-col h-full gap-4 p-6 rounded-2xl border border-slate-200 bg-white hover:bg-slate-50 transition-colors duration-300"
>
    <div class="flex flex-col items-start gap-2">
        <time
            datetime={date.toISOString()}
            class="text-sm font-medium text-slate-500"
        >
            {dateString}
        </time>
        <h2 class="text-xl md:text-2xl font-bold tracking-tight">{title}</h2>
    </div>
    {
        description && (
            <p class="text-slate-500 text-sm md:text-base leading-relaxed line-clamp-2">
                {description}
            </p>
        )
    }
    {
        tags && tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-auto pt-4">
                {tags.map((tag) => (
                    <span class="inline-flex items-center px-2.5 py-1 rounded-sm bg-slate-100 text-xs font-medium text-slate-700">
                        # {tag.name}
                    </span>
                ))}
            </div>
        )
    }
</a>
