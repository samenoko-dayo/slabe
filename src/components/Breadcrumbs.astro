---
import { ChevronRight, House } from "@lucide/astro";

export interface BreadcrumbItem {
    label: string;
    href?: string;
}

export interface Props {
    items: BreadcrumbItem[];
    class?: string;
}

const { items = [], class: className } = Astro.props;
---

<nav
    aria-label="Breadcrumb"
    class:list={[
        "flex overflow-x-auto whitespace-nowrap py-2 text-sm text-neutral-500 dark:text-neutral-400",
        className,
    ]}
>
    <ol class="flex items-center space-x-1.5 sm:space-x-2">
        <li class="inline-flex items-center">
            <a
                href="/"
                class="inline-flex items-center gap-1.5 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded-sm"
            >
                <House class="w-4 h-4 shrink-0" />
                <span class="sr-only">ホーム</span>
            </a>
        </li>
        {
            items.map((item, index) => {
                const isLast = index === items.length - 1;
                return (
                    <li class="inline-flex items-center">
                        <ChevronRight class="w-4 h-4 text-neutral-400 dark:text-neutral-500 shrink-0" />
                        {isLast || !item.href ? (
                            <span
                                class="ml-1.5 sm:ml-2 font-medium text-neutral-900 dark:text-neutral-100"
                                aria-current={isLast ? "page" : undefined}
                            >
                                {item.label}
                            </span>
                        ) : (
                            <a
                                href={item.href}
                                class="ml-1.5 sm:ml-2 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded-sm"
                            >
                                {item.label}
                            </a>
                        )}
                    </li>
                );
            })
        }
    </ol>
</nav>
