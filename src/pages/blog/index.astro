---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
    <section class="py-12 md:py-16 flex flex-col items-start text-left">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
            記事一覧
        </h1>
        <p class="text-lg md:text-xl text-slate-500 leading-relaxed">
            {sortedPosts.length}件の記事があります
        </p>
    </section>
    <section
        class="py-12 flex flex-col items-start gap-8 border-t border-slate-100"
    >
        <div
            class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        >
            {sortedPosts.map((post) => <PostCard post={post} />)}
        </div>
    </section>
</Layout>
