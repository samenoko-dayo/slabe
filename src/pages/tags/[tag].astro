---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog", ({ data }) => import.meta.env.DEV || data.draft !== true);
    const uniqueTags = [
        ...new Set(
            allPosts.flatMap(
                (post) => post.data.tags?.map((tag) => tag.name) || [],
            ),
        ),
    ];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags?.some((t) => t.name === tag))
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`タグ: ${tag}`} description={`${tag}タグが付いた記事の一覧ページです`}>
    <section class="py-12 md:py-16 flex flex-col items-start text-left">
        <Breadcrumbs 
          items={[
            { label: "タグ", href: "/tags" },
            { label: tag }
          ]} 
          class="mb-6 w-full" 
        />
        <p
            class="text-sm font-semibold text-slate-500 mb-2 uppercase tracking-wide"
        >
            タグ
        </p>
        <h1
            class="text-4xl font-bold tracking-tight text-slate-900 flex items-center gap-3"
        >
            <span class="text-slate-500">#</span>{tag}
        </h1>
        <p class="mt-4 text-slate-600">
            {posts.length} 件の記事が見つかりました。
        </p>
    </section>
    <section
        class="py-12 flex flex-col items-start gap-8 border-t border-slate-100"
    >
        <div
            class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        >
            {posts.map((post) => <PostCard post={post} />)}
        </div>
    </section>
</Layout>
